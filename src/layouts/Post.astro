---
import Base from './Base.astro'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const { title, date, tags } = post.data

const fmt = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<Base title={`${title} — Hagen Fritz`} description={post.data.summary}>
  <article>
    <header class="mb-8 space-y-3">
      <a href="/blog" class="text-sm text-muted-foreground hover:text-primary">
        ← Blog
      </a>
      <h1 class="text-3xl font-semibold tracking-tight">{title}</h1>
      <div
        class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground"
      >
        <time>{fmt}</time>
        {
          tags.map((t) => (
            <span class="rounded bg-muted px-1.5 py-0.5 text-[11px]">{t}</span>
          ))
        }
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
